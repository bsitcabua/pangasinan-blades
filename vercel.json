{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/share", "destination": "/api/share" },
    { "source": "/share/", "destination": "/api/share" }
  ],
  "cleanUrls": true,
  "trailingSlash": true
}
